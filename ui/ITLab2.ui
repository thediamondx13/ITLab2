   <string notr="true">QMainWindow { background-color: #1e1e2e; }
QLabel { color: #cdd6f4; font-size: 13px; font-weight: 500; }
QTextEdit, QLineEdit { background-color: #313244; color: #cdd6f4; border: 2px solid #45475a; border-radius: 6px; padding: 8px; font-size: 12px; font-family: monospace; selection-background-color: #89b4fa; }
QTextEdit:focus, QLineEdit:focus { border: 2px solid #89b4fa; }
QPushButton { background-color: #89b4fa; color: #1e1e2e; border: none; border-radius: 6px; padding: 10px 20px; font-weight: bold; font-size: 13px; }
QPushButton:hover { background-color: #b4befe; }
QPushButton:pressed { background-color: #74c7ec; }
QPushButton#btnLoad { background-color: #a6e3a1; color: #1e1e2e; }
QPushButton#btnLoad:hover { background-color: #94e2d5; }
QPushButton#btnSave { background-color: #a6e3a1; color: #1e1e2e; }
QPushButton#btnSave:hover { background-color: #94e2d5; }
QGroupBox { color: #89b4fa; font-weight: bold; font-size: 14px; border: 2px solid #313244; border-radius: 8px; margin-top: 12px; padding-top: 16px; }
QGroupBox::title { subcontrol-origin: margin; left: 12px; padding: 0 8px; }
QProgressBar { border: 2px solid #45475a; border-radius: 6px; background-color: #313244; color: #cdd6f4; text-align: center; font-weight: bold; font-size: 12px; }
QProgressBar::chunk { background-color: #89b4fa; border-radius: 4px; }</string>
